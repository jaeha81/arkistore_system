{
  "permissions": {
    "allow": [
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001)",
      "Bash(docker-compose up:*)",
      "Bash(pg_isready -h localhost -p 5432)",
      "Bash(pg_ctl status:*)",
      "Bash(powershell.exe -Command \"Get-Service -Name ''postgresql*'' 2>/dev/null | Select-Object Name, Status\")",
      "Bash(powershell.exe -Command \"Get-Service -Name ''postgresql*'' | Select-Object Name, Status | Format-Table\")",
      "Bash(psql -U arkistore -d arkistore_db -c l)",
      "Bash(psql -U postgres -c l)"
    ]
  }
}
