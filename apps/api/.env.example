# ============================================================
# Arkistore Operations API — 환경변수 전체 목록
# 실제 .env 파일은 .gitignore에 포함됨 (절대 커밋 금지)
# ============================================================

# ── 기본 앱 설정 ────────────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_TITLE=Arkistore Operations API
APP_VERSION=1.0.0
DEBUG=true

# ── 데이터베이스 ─────────────────────────────────────────────
# PostgreSQL 15+ 필요
DATABASE_URL=postgresql+asyncpg://arkistore:password@localhost:5432/arkistore_db
# 테스트용 (pytest — SQLite in-memory)
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# ── JWT 인증 ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-very-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_DOMAIN=localhost                  # production: .arkistore.com

# ── CORS 허용 오리진 ─────────────────────────────────────────
# 쉼표 구분
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── GitHub 연동 ──────────────────────────────────────────────
# Settings → Developer settings → Personal access tokens (classic)
# 권한: repo (Issues read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_DEFAULT_REPO=your-org/your-repo  # 이슈 생성 기본 레포

# ── Google 서비스 계정 (Sheets + Drive) ───────────────────────
# GCP → IAM → 서비스 계정 → JSON 키 발급
# 키 파일 전체 내용을 한 줄 JSON 문자열로 변환
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=                  # 업로드 기본 폴더 ID

# ── 파일 스토리지 ────────────────────────────────────────────
# S3 호환 스토리지 (AWS S3 / MinIO / Cloudflare R2)
STORAGE_PROVIDER=mock                    # mock | s3 | gcs
STORAGE_BUCKET=arkistore-files
STORAGE_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# MinIO 사용 시
STORAGE_ENDPOINT_URL=http://localhost:9000

# ── 외부 연동 — Mock/Real 전환 ───────────────────────────────
# true = Mock 데이터 반환, false = 실제 API 호출
USE_MOCK_ECOUNT=true
USE_MOCK_NINE_UNITED=true
USE_MOCK_CUSTOMS=true

# Ecount ERP
ECOUNT_API_URL=https://ecount.com/ECERP/WEBAPI
ECOUNT_COM_CODE=                         # Ecount 회사 코드
ECOUNT_API_KEY=                          # Ecount API 인증키

# Nine United 배송 포털
NINE_UNITED_API_URL=https://api.9united.co.kr
NINE_UNITED_API_KEY=

# UNI-PASS 통관조회
UNIPASS_API_URL=https://unipass.customs.go.kr/ext/rest
UNIPASS_API_KEY=                         # 관세청 UNI-PASS 신청 필요

# ── 로깅 ─────────────────────────────────────────────────────
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                          # json | text

# ── 보안 ─────────────────────────────────────────────────────
ENCRYPTION_KEY=                          # 고객 전화/이메일 암호화용 Fernet 키
                                         # 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
